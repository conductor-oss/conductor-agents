# Scan artifacts
/reports/*
!/reports/.gitkeep

# Persistent cross-run knowledge store
/state/

# Runtime state written by workers — per-target dossiers/traces, captured sessions, OOB tunnel
# state. MAY CONTAIN LIVE TOKENS / PII from real targets; never commit.
/workers/state/
# OOB worker: track the source, ignore only its runtime state (port/token info).
/workers/oob/state.json

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Env / secrets
.env
*.local

# Local-only target profile (kept on disk, not shipped)
/profiles/conductor.json

# Conductor local-server embedded DB (created in cwd when the server starts here)
c123.db*
*.db
*.db-shm
*.db-wal

# OS
.DS_Store

# Scratch
.scratch/
