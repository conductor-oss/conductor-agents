# Base worker image: normalize_target, recon, persist (pure Python).
FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app

# WORKER_MODULES selects which task packages to load (default: recon).
CMD ["python", "main.py"]
