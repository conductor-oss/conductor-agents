# ── Conductor connection (workers + CLI) ────────────────────────────────────
# Local OSS server started via `conductor server start`:
CONDUCTOR_SERVER_URL=http://localhost:8080/api
# For an Orkes/Enterprise server, also set:
# CONDUCTOR_AUTH_KEY=
# CONDUCTOR_AUTH_SECRET=

# ── LLM provider (read by the Conductor SERVER, not the workers) ─────────────
# The server auto-enables the Anthropic provider when this is in its environment.
# Start the server from a shell that exports it.
ANTHROPIC_API_KEY=

# ── Scanner runtime ──────────────────────────────────────────────────────────
# Where scan artifacts (findings.json, report.md, report.pdf) are written.
REPORTS_DIR=./reports

# LLM models used by the workflow tasks (override per environment).
SCAN_LLM_PROVIDER=anthropic
SCAN_LLM_MODEL=claude-sonnet-4-6
