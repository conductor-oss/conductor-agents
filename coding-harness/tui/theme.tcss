/* Harness TUI — one dark theme. */

Screen {
    background: $surface;
}

/* ---- Global factory bar ---- */
FactoryTopBar {
    height: 6;
    min-height: 6;
    padding: 0 1;
    background: #53575d;
    border-bottom: solid #363a42;
}
#factory_logo {
    width: 100%;
    height: 4;
    content-align: left middle;
}
#factory_meta {
    width: 100%;
    height: 1;
}
#factory_title {
    width: 1fr;
    height: 1;
    color: $text;
    text-style: bold;
}
#factory_stats {
    width: auto;
    min-width: 40;
    height: 1;
    content-align: right middle;
}
FactoryTopBar.-degraded {
    background: #53575d;
    border-bottom: solid $warning;
}
FactoryTopBar.-down {
    background: #53575d;
    border-bottom: solid $error;
}

/* ---- Dashboard ---- */
#run_table {
    height: 1fr;
}
#dash_hint {
    height: 1;
    color: $text-muted;
    padding: 0 1;
}

/* ---- Launcher ---- */
#action_list {
    height: auto;
    max-height: 12;
    border: round $primary;
    margin: 1 2;
}
LauncherForm {
    padding: 1 2;
}
LauncherForm .field-row {
    height: auto;
    margin-bottom: 1;
}
LauncherForm Label {
    width: 18;
    color: $text-muted;
}
LauncherForm .field-help {
    color: $text-muted;
    text-style: italic;
}
Preflight {
    height: auto;
    border-top: solid $panel;
    padding: 1 0 0 0;
    margin-top: 1;
}
Preflight.-ok  { color: $success; }
Preflight.-bad { color: $error; }

/* ---- Run detail ---- */
#detail_body {
    height: 1fr;
}
#task_tree {
    width: 44%;
    border-right: solid $panel;
}
#agent_pane {
    width: 1fr;
    padding: 0 1;
}
TurnLog {
    height: 1fr;
}
ResultCard {
    padding: 1 2;
    height: auto;
}
ResultCard .rc-title { text-style: bold; }
ResultCard .rc-link  { color: $accent; text-style: underline; }

/* ---- modals ---- */
ConfirmModal, LogsModal, NewTemplateModal, SaveTemplateModal, ApprovalModal, FileListModal, FilePreviewModal {
    align: center middle;
}
ConfirmModal > #box, LogsModal > #box, NewTemplateModal > #box,
SaveTemplateModal > #box, ApprovalModal > #box, FileListModal > #box, FilePreviewModal > #box {
    width: 70%;
    max-width: 100;
    height: auto;
    max-height: 80%;
    border: round $primary;
    background: $panel;
    padding: 1 2;
}
NewTemplateModal #nt_scope, SaveTemplateModal .field-row { margin-top: 1; }

#tpl_banner {
    color: $accent;
    background: $panel;
    padding: 0 1;
    margin-bottom: 1;
}
LogsModal #log_body {
    height: 1fr;
    min-height: 10;
}
.modal-buttons {
    height: auto;
    align-horizontal: right;
    margin-top: 1;
}
ApprovalModal #design_feedback, ApprovalModal #campaign_feedback {
    height: 6;
    min-height: 4;
    margin-top: 1;
    border: round $primary;
}
ApprovalModal #campaign_profile, ApprovalModal #campaign_checks,
ApprovalModal #campaign_wave_profile, ApprovalModal #campaign_final_profile,
ApprovalModal #campaign_max_turns, ApprovalModal #campaign_max_budget {
    margin-top: 1;
}
FilePreviewModal #file_preview_scroll {
    height: 1fr;
    min-height: 12;
    border: round $primary;
    padding: 1;
}

/* ---- chat ---- */
#chat_header {
    height: 1;
    background: $panel;
    padding: 0 1;
}
#transcript {
    height: 1fr;
    padding: 1 1 0 1;
}
#chat_input {
    dock: bottom;
    margin: 0 1 1 1;
}
.bubble {
    height: auto;
    margin-bottom: 1;
}
.bubble-tool { color: $text-muted; }
.bubble-system { color: $text-muted; text-style: italic; }
#session_list {
    height: 1fr;
    border: round $primary;
    margin: 1 2;
}

/* ---- generic ---- */
.banner-error {
    background: $error;
    color: $text;
    text-style: bold;
    padding: 1 2;
}
.muted { color: $text-muted; }

#help_box {
    width: auto;
    height: auto;
    border: round $primary;
    background: $panel;
    padding: 1 2;
}
