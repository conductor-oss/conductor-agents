{
  "_about": "Version-2 feature-campaign checks. Commands are repository configuration; credentials are never stored here.",
  "version": 2,
  "checks": {
    "unit": {"command": ["make", "test-unit"], "blocking": true, "retries": 0},
    "lint": {"command": ["make", "lint"], "blocking": false, "retries": 0},
    "integration": {"command": ["make", "test-integration"], "blocking": true, "retries": 1},
    "smoke-attached": {"command": ["scripts/smoke.sh"], "blocking": true, "retries": 0}
  },
  "profiles": {
    "wave": {
      "checks": ["unit", "lint"],
      "environment": {"mode": "none"}
    },
    "managed-final": {
      "checks": ["unit", "integration"],
      "environment": {
        "mode": "managed",
        "up": ["docker", "compose", "-f", "test/cluster.yml", "up", "-d", "--wait"],
        "readyCheck": ["scripts/wait-healthy.sh"],
        "down": ["docker", "compose", "-f", "test/cluster.yml", "down", "-v"]
      }
    },
    "attached": {
      "checks": ["smoke-attached"],
      "environment": {
        "mode": "attached",
        "readyCheck": ["scripts/wait-attached.sh"],
        "requiredEnv": ["TEST_SERVER_URL"]
      }
    }
  },
  "defaults": {"waveProfile": "wave", "finalProfile": "managed-final"}
}
