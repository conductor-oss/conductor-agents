{
  "version": 1,
  "name": "Example team policy",
  "description": "Declarative workflow model policy. Keep credentials and commands outside this file.",
  "workflows": ["code_parallel", "feature_campaign", "openspec_development"],
  "repos": ["acme/service"],
  "defaultProfile": "team-standard",
  "profiles": {
    "team-standard": {
      "roles": {
        "design": {"agent": "claude", "model": "claude-opus-4-8", "maxBudgetUsd": 25},
        "plan": {"agent": "claude", "model": "claude-opus-4-8", "maxBudgetUsd": 25},
        "code": {"tiers": [
          {"agent": "claude", "model": "claude-sonnet-5", "maxBudgetUsd": 25},
          {"agent": "claude", "model": "claude-opus-4-8", "maxBudgetUsd": 50}
        ]},
        "review": {"agent": "codex", "model": "gpt-5.6-terra"},
        "judge": {"agent": "codex", "model": "gpt-5.6-terra"},
        "scribe": {"agent": "claude", "model": "claude-haiku-4-5"}
      }
    }
  },
  "prices": {
    "claude-opus-4-8": {"input": 5, "output": 25},
    "claude-sonnet-5": {"input": 3, "output": 15},
    "claude-haiku-4-5": {"input": 1, "output": 5},
    "gpt-5.6-terra": {"input": 2.5, "output": 15}
  }
}
