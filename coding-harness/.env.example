# coding-harness environment configuration — copy to `.env` and edit.
#
# `./run.sh`, `workers/register.sh`, and `workers/run_workers.sh` auto-load `.env`
# from this directory as defaults; explicitly exported Conductor variables win.
# When invoking `workers/main.py` directly, export these yourself or run:
#     set -a; . ./.env; set +a
#
# `.env` is gitignored. Never commit real secrets.

# ── Conductor connection (workers + register/CLI) ───────────────────────────
# Conductor server API base. Local OSS server: `conductor server start`.
CONDUCTOR_SERVER_URL=http://localhost:8080/api
# Orkes/Enterprise auth — leave unset for a local OSS server. The bootstrap CLI,
# TUI, registration, and Python workers inherit these when BOTH are present.
# CONDUCTOR_AUTH_KEY=
# CONDUCTOR_AUTH_SECRET=
# Optional explicit server type. Credentials already disable local OSS fallback.
# CONDUCTOR_SERVER_TYPE=Enterprise

# Local server backend `./run.sh` brings up: "sqlite" (default, conductor server
# start — zero extra deps) or "postgres" (docker compose -f docker-compose.postgres.yml
# — requires Docker). Reach for postgres when a parallel-heavy workflow
# (code_parallel, openspec_plan) fails with NonTransientException: [SQLITE_BUSY...]
# against the default server.
# CONDUCTOR_BACKEND=sqlite
# Only used when CONDUCTOR_BACKEND=postgres:
# POSTGRES_USER=conductor
# POSTGRES_PASSWORD=conductor
# POSTGRES_DB=conductor
# POSTGRES_PORT=5432
# CONDUCTOR_IMAGE_TAG=3.22.3

# ── Backends / API keys ─────────────────────────────────────────────────────
# At least one backend must be authenticated. Keys are consumed by each backend's
# SDK/CLI (never logged by the workers).
# Claude (default backend): `claude login` OR this key.
ANTHROPIC_API_KEY=
# OpenAI Codex backend: `~/.codex/auth.json` (login) OR this key.
OPENAI_API_KEY=
# Google Gemini backend: this key (or ~/.gemini/.env). Requires the `gemini` CLI.
GEMINI_API_KEY=

# ── GitHub (issue_to_pr, pr_review, address_pr, github_demo) ─────────────────
# Remote git/PR ops authenticate through the `gh` CLI. Prefer `gh auth login`;
# alternatively set a token here (PAT with `repo` scope).
# GH_TOKEN=

# ── Logging ──────────────────────────────────────────────────────────────────
# Worker log level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# ── Tuning / worker behavior ─────────────────────────────────────────────────
# Task modules main.py loads (comma-separated). Split across hosts, e.g.
# WORKER_MODULES=coding_agent (heavy LLM) vs WORKER_MODULES=gitops,openspecops (light
# git/gh + openspec CLI).
WORKER_MODULES=coding_agent,gitops,openspecops

# Backend CLI binaries — override only if not on PATH under the default name.
CODEX_BIN=codex
GEMINI_BIN=gemini
# Codex driver: "sdk" (default, bundled openai-codex) or "cli" (codex exec fallback).
CODEX_DRIVER=sdk

# Which filesystem settings the Claude agent loads. "project" (default) loads the
# target repo's CLAUDE.md AND its .claude/settings.json (hooks/allow-rules). For
# UNTRUSTED repos set empty or "none" so nothing repo-controlled reaches the agent.
# The per-task `settingSources` input overrides this.
# CODING_AGENT_SETTING_SOURCES=project

# Repo-resident prompt-template layer (.conductor/<key>.md) — a repo-controlled
# injection vector like CLAUDE.md. Set 0 to disable for untrusted repos. Default on.
CODING_AGENT_REPO_TEMPLATES=1

# Repo-guide ingestion (AGENTS.md/…) — repo-controlled content. Set 0 to disable
# for untrusted repos. Default on.
CODING_AGENT_REPO_GUIDE=1

# Shared-volume session store for cross-host session resume. Unset = host-local
# sessions only. Point at a shared/persistent dir to resume across worker hosts.
# CODING_AGENT_SESSION_STORE_DIR=./.cc-sessions

# ── Config files (not env vars) ──────────────────────────────────────────────
# Live runtime config the workers actually read:
#   workers/defaults/policy.defaults.json   guardrail + budget policy
#   workers/defaults/prompts/*.md           task prompts (read at runtime)
# Active declarative model-policy example and a verification-profile example:
#   docs/config/checks.example.json         verification-suite schema
#   docs/config/models.example.json         model-policy starter
# Copy the model example to `.conductor-code/models.json` or the single user policy file;
# it is validated before agent or repository mutation. The checks example remains an operator
# configuration example and is selected by workflow input.
