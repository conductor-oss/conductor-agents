{
  "name": "code_parallel",
  "version": 3,
  "schemaVersion": 2,
  "ownerEmail": "viren@orkes.io",
  "description": "Parallelize the coding agent: openspec_plan drives the openspec CLI to produce a proposal/specs/design/tasks change (reviewed via a human-or-AI-judge loop) and deterministically parses tasks.md into independent sub-tasks, a JQ task reshapes them into a dynamic fork, FORK_JOIN_DYNAMIC runs a code_subtask (worktree->coding_agent->commit) per sub-task in parallel, then merge_worktrees merges the branches back into a change branch.",
  "inputParameters": [
    "repoPath",
    "instruction",
    "changeBranch",
    "openspecPlanAgent",
    "openspecPlanModel",
    "openspecMaxTurns",
    "openspecMaxBudgetUsd",
    "openspecHumanApproval",
    "openspecMaxIterations",
    "codeAgent",
    "codeModel",
    "codePromptTemplate",
    "codePromptTemplateSource",
    "maxTurns",
    "maxBudgetUsd",
    "modelProfile",
    "modelPolicy",
    "modelPolicySource",
    "modelPolicySha256",
    "modelsConfig",
    "modelOverrides",
    "precomputedPlan",
    "specContextPath",
    "usePrecomputedPlan"
  ],
  "inputTemplate": {
    "changeBranch": "code-parallel",
    "openspecPlanAgent": "claude",
    "openspecPlanModel": "",
    "openspecMaxTurns": 500,
    "openspecMaxBudgetUsd": 50.0,
    "openspecHumanApproval": true,
    "openspecMaxIterations": 5,
    "codeAgent": "claude",
    "codeModel": "",
    "codePromptTemplate": "",
    "codePromptTemplateSource": "",
    "maxTurns": 500,
    "maxBudgetUsd": 50.0,
    "modelProfile": "",
    "modelPolicy": {},
    "modelPolicySource": "",
    "modelPolicySha256": "",
    "modelsConfig": "",
    "modelOverrides": {},
    "precomputedPlan": {},
    "specContextPath": "",
    "usePrecomputedPlan": false
  },
  "tasks": [
    {
      "name": "model_profile_resolve",
      "taskReferenceName": "model_policy",
      "type": "SIMPLE",
      "inputParameters": {
        "modelProfile": "${workflow.input.modelProfile}",
        "modelPolicy": "${workflow.input.modelPolicy}",
        "modelPolicySource": "${workflow.input.modelPolicySource}",
        "modelPolicySha256": "${workflow.input.modelPolicySha256}",
        "modelsConfig": "${workflow.input.modelsConfig}",
        "modelOverrides": "${workflow.input.modelOverrides}",
        "repoPath": "${workflow.input.repoPath}"
      }
    },
    {
      "name": "prepare_repo",
      "taskReferenceName": "prep",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${workflow.input.repoPath}"
      }
    },
    {
      "name": "create_branch",
      "taskReferenceName": "branch",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${workflow.input.repoPath}",
        "name": "${workflow.input.changeBranch}"
      }
    },
    {
      "name": "openspec_plan",
      "taskReferenceName": "openspec_plan",
      "type": "SUB_WORKFLOW",
      "subWorkflowParam": {
        "name": "openspec_plan",
        "version": 1
      },
      "inputParameters": {
        "repoPath": "${workflow.input.repoPath}",
        "instruction": "${workflow.input.instruction}",
        "changeBranch": "${workflow.input.changeBranch}",
        "openspecPlanAgent": "${workflow.input.openspecPlanAgent}",
        "openspecPlanModel": "${workflow.input.openspecPlanModel}",
        "openspecMaxTurns": "${workflow.input.openspecMaxTurns}",
        "openspecMaxBudgetUsd": "${workflow.input.openspecMaxBudgetUsd}",
        "openspecHumanApproval": "${workflow.input.openspecHumanApproval}",
        "openspecMaxIterations": "${workflow.input.openspecMaxIterations}",
        "modelProfile": "${workflow.input.modelProfile}",
        "modelPolicy": "${workflow.input.modelPolicy}",
        "modelPolicySource": "${workflow.input.modelPolicySource}",
        "modelPolicySha256": "${workflow.input.modelPolicySha256}",
        "modelsConfig": "${workflow.input.modelsConfig}",
        "modelOverrides": "${workflow.input.modelOverrides}"
      }
    },
    {
      "name": "build_forks",
      "taskReferenceName": "build_forks",
      "type": "JSON_JQ_TRANSFORM",
      "inputParameters": {
        "result": "${openspec_plan.output}",
        "changeDir": "${openspec_plan.output.changeDir}",
        "precomputedPlan": "${workflow.input.precomputedPlan}",
        "usePrecomputedPlan": "${workflow.input.usePrecomputedPlan}",
        "specContextPath": "${workflow.input.specContextPath}",
        "repoPath": "${workflow.input.repoPath}",
        "codeModel": "${workflow.input.codeModel}",
        "codeAgent": "${workflow.input.codeAgent}",
        "codePromptTemplate": "${workflow.input.codePromptTemplate}",
        "codePromptTemplateSource": "${workflow.input.codePromptTemplateSource}",
        "maxTurns": "${workflow.input.maxTurns}",
        "maxBudgetUsd": "${workflow.input.maxBudgetUsd}",
        "modelProfile": "${workflow.input.modelProfile}",
        "modelPolicy": "${workflow.input.modelPolicy}",
        "modelPolicySource": "${workflow.input.modelPolicySource}",
        "modelPolicySha256": "${workflow.input.modelPolicySha256}",
        "modelsConfig": "${workflow.input.modelsConfig}",
        "modelOverrides": "${workflow.input.modelOverrides}",
        "queryExpression": ".repoPath as $r | .codeModel as $m | .codeAgent as $ag | .codePromptTemplate as $ct | .codePromptTemplateSource as $cts | .maxTurns as $mt | .maxBudgetUsd as $mb | .changeDir as $cd | .specContextPath as $sc | .modelProfile as $mp | .modelPolicy as $mpp | .modelPolicySource as $mps | .modelPolicySha256 as $mpsh | .modelsConfig as $mc | .modelOverrides as $mo | (if .usePrecomputedPlan then .precomputedPlan else .result end).subtasks as $subs | {dynamicTasks: [$subs[] | {name:\"code_subtask\", taskReferenceName:.id, type:\"SUB_WORKFLOW\", subWorkflowParam:{name:\"code_subtask\", version:2}}], dynamicTasksInput: (reduce $subs[] as $s ({}; . + ((($s.files // []) | join(\", \")) as $files | ($s.description + \"\\nTarget files: \" + $files + (if $s.testCmd then \"\\nYour check: \" + $s.testCmd else \"\" end)) as $desc | {($s.id): {repoPath:$r, name:$s.id, model:$m, agent:$ag, maxTurns:$mt, maxBudgetUsd:$mb, prompt:($desc + \"\\n\\nThe OpenSpec planning artifacts for this change are under \" + $cd + \" in your working directory — read proposal.md and design.md first, then specs/**/*.md, then your slice of tasks.md, before implementing.\"), promptTemplate:$ct, promptTemplateSource:$cts, templateKey:\"code\", promptContext:{subtask:$desc}, specContextPath:$sc, modelProfile:$mp, modelPolicy:$mpp, modelPolicySource:$mps, modelPolicySha256:$mpsh, modelsConfig:$mc, modelOverrides:$mo}}))), groupIds: ([$subs[].id] | join(\",\"))}"
      }
    },
    {
      "name": "fan_out",
      "taskReferenceName": "fan_out",
      "type": "FORK_JOIN_DYNAMIC",
      "dynamicForkTasksParam": "dynamicTasks",
      "dynamicForkTasksInputParamName": "dynamicTasksInput",
      "inputParameters": {
        "dynamicTasks": "${build_forks.output.result.dynamicTasks}",
        "dynamicTasksInput": "${build_forks.output.result.dynamicTasksInput}"
      }
    },
    {
      "name": "fan_join",
      "taskReferenceName": "fan_join",
      "type": "JOIN"
    },
    {
      "name": "merge_worktrees",
      "taskReferenceName": "merge",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${workflow.input.repoPath}",
        "groupIds": "${build_forks.output.result.groupIds}",
        "modelBuilder": "${workflow.input.codeModel}",
        "maxBudgetUsd": "${workflow.input.maxBudgetUsd}"
      }
    },
    {
      "name": "aggregate",
      "taskReferenceName": "aggregate",
      "type": "JSON_JQ_TRANSFORM",
      "optional": true,
      "inputParameters": {
        "joined": "${fan_join.output}",
        "planTokens": "${openspec_plan.output.tokenUsed}",
        "planCost": "${openspec_plan.output.costUsd}",
        "mergeTokens": "${merge.output.tokenUsed}",
        "mergeCost": "${merge.output.costUsd}",
        "queryExpression": "def num: if type == \"number\" then . else 0 end; (.joined // {}) as $j | [$j | to_entries[] | (.value.output // .value // {}) | {status:(.status // \"unknown\"), filesChanged:(.filesChanged // []), costUsd:(.costUsd | num), tokenUsed:(.tokenUsed | num)}] as $g | (.planTokens | num) as $pt | (.planCost | num) as $pc | (.mergeTokens | num) as $mt | (.mergeCost | num) as $mc | ([$g[].tokenUsed] | add | num) as $st | ([$g[].costUsd] | add | num) as $sc | {perSubtask:$g, subtaskCount:($g | length), tokens:{plan:$pt, subtasks:$st, merge:$mt}, cost:{plan:$pc, subtasks:$sc, merge:$mc}, totalTokens:($pt + $st + $mt), totalCostUsd:($pc + $sc + $mc)}"
      }
    }
  ],
  "outputParameters": {
    "changeBranch": "${workflow.input.changeBranch}",
    "groupIds": "${build_forks.output.result.groupIds}",
    "subtasks": "${openspec_plan.output.subtasks}",
    "merged": "${merge.output.merged}",
    "conflicts": "${merge.output.conflicts}",
    "mergeCostUsd": "${merge.output.costUsd}",
    "totalTokens": "${aggregate.output.result.totalTokens}",
    "totalCostUsd": "${aggregate.output.result.totalCostUsd}",
    "summary": "${aggregate.output.result}"
  }
}
