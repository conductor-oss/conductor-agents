{
  "name": "code_subtask",
  "version": 1,
  "schemaVersion": 2,
  "ownerEmail": "viren@orkes.io",
  "description": "One parallel sub-task of code_parallel: create a git worktree/branch, run the coding_agent in it, and commit the changes on that branch so merge_worktrees can merge it back.",
  "inputParameters": [
    "repoPath",
    "name",
    "prompt",
    "promptTemplate",
    "templateKey",
    "promptContext",
    "model",
    "agent",
    "maxTurns",
    "maxBudgetUsd",
    "testCmd"
  ],
  "inputTemplate": {
    "promptTemplate": "",
    "templateKey": "code",
    "promptContext": {},
    "maxTurns": 250,
    "maxBudgetUsd": 50.0,
    "testCmd": ""
  },
  "tasks": [
    {
      "name": "worktree_add",
      "taskReferenceName": "wt",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${workflow.input.repoPath}",
        "name": "${workflow.input.name}"
      }
    },
    {
      "name": "coding_agent",
      "taskReferenceName": "code",
      "type": "SIMPLE",
      "inputParameters": {
        "worktreePath": "${wt.output.worktreePath}",
        "prompt": "${workflow.input.prompt}",
        "promptTemplate": "${workflow.input.promptTemplate}",
        "templateKey": "${workflow.input.templateKey}",
        "promptContext": "${workflow.input.promptContext}",
        "model": "${workflow.input.model}",
        "agent": "${workflow.input.agent}",
        "maxTurns": "${workflow.input.maxTurns}",
        "maxBudgetUsd": "${workflow.input.maxBudgetUsd}"
      }
    },
    {
      "name": "run_checks",
      "taskReferenceName": "check",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${wt.output.worktreePath}",
        "cmd": "${workflow.input.testCmd}",
        "label": "${workflow.input.name}"
      }
    },
    {
      "name": "verify_gate",
      "taskReferenceName": "verify_gate",
      "type": "SWITCH",
      "evaluatorType": "value-param",
      "expression": "passed",
      "inputParameters": {
        "passed": "${check.output.passed}"
      },
      "decisionCases": {
        "true": [
          {
            "name": "commit",
            "taskReferenceName": "cmt",
            "type": "SIMPLE",
            "inputParameters": {
              "repoPath": "${wt.output.worktreePath}",
              "message": "code_subtask ${workflow.input.name}"
            }
          }
        ]
      },
      "defaultCase": []
    }
  ],
  "outputParameters": {
    "status": "${code.output.status}",
    "agent": "${code.output.agent}",
    "model": "${code.output.model}",
    "filesChanged": "${code.output.filesChanged}",
    "costUsd": "${code.output.costUsd}",
    "tokenUsed": "${code.output.tokenUsed}",
    "numTurns": "${code.output.numTurns}",
    "turns": "${code.output.turns}",
    "branch": "${wt.output.branch}",
    "commit": "${cmt.output.commit}",
    "verified": "${check.output.passed}",
    "checkRan": "${check.output.ran}",
    "checkExitCode": "${check.output.exitCode}",
    "checkCmd": "${check.output.cmd}"
  }
}
