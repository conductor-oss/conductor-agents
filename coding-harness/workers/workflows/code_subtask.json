{
  "name": "code_subtask",
  "version": 2,
  "schemaVersion": 2,
  "ownerEmail": "viren@orkes.io",
  "description": "One parallel sub-task of code_parallel: create a git worktree/branch, run the coding_agent in it, and commit the changes on that branch so merge_worktrees can merge it back.",
  "inputParameters": [
    "agent",
    "maxBudgetUsd",
    "maxTurns",
    "model",
    "modelOverrides",
    "modelPolicy",
    "modelPolicySha256",
    "modelPolicySource",
    "modelProfile",
    "modelsConfig",
    "name",
    "prompt",
    "promptContext",
    "promptTemplate",
    "promptTemplateSource",
    "repoPath",
    "specContextPath",
    "templateKey"
  ],
  "inputTemplate": {
    "promptTemplate": "",
    "promptTemplateSource": "",
    "templateKey": "code",
    "promptContext": {},
    "maxTurns": 250,
    "maxBudgetUsd": 50.0,
    "modelProfile": "",
    "modelPolicy": {},
    "modelPolicySource": "",
    "modelPolicySha256": "",
    "modelsConfig": "",
    "modelOverrides": {}
    ,"specContextPath": ""
  },
  "tasks": [
    {
      "name": "model_profile_resolve",
      "taskReferenceName": "model_policy",
      "type": "SIMPLE",
      "inputParameters": {
        "modelProfile": "${workflow.input.modelProfile}",
        "modelPolicy": "${workflow.input.modelPolicy}",
        "modelPolicySource": "${workflow.input.modelPolicySource}",
        "modelPolicySha256": "${workflow.input.modelPolicySha256}",
        "modelsConfig": "${workflow.input.modelsConfig}",
        "modelOverrides": "${workflow.input.modelOverrides}",
        "repoPath": "${workflow.input.repoPath}"
      }
    },
    {
      "name": "worktree_add",
      "taskReferenceName": "wt",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${workflow.input.repoPath}",
        "name": "${workflow.input.name}"
      }
    },
    {
      "name": "coding_agent",
      "taskReferenceName": "code",
      "type": "SIMPLE",
      "inputParameters": {
        "worktreePath": "${wt.output.worktreePath}",
        "contextFiles": [
          "${workflow.input.specContextPath}"
        ],
        "prompt": "${workflow.input.prompt}",
        "promptTemplate": "${workflow.input.promptTemplate}",
        "promptTemplateSource": "${workflow.input.promptTemplateSource}",
        "templateKey": "${workflow.input.templateKey}",
        "promptContext": "${workflow.input.promptContext}",
        "model": "${workflow.input.model}",
        "agent": "${workflow.input.agent}",
        "maxTurns": "${workflow.input.maxTurns}",
        "maxBudgetUsd": "${workflow.input.maxBudgetUsd}",
        "modelRole": "code",
        "modelProfile": "${workflow.input.modelProfile}",
        "modelPolicy": "${workflow.input.modelPolicy}",
        "modelPolicySource": "${workflow.input.modelPolicySource}",
        "modelPolicySha256": "${workflow.input.modelPolicySha256}",
        "modelsConfig": "${workflow.input.modelsConfig}",
        "modelOverrides": "${workflow.input.modelOverrides}",
        "modelResolution": "${model_policy.output}"
      }
    },
    {
      "name": "commit",
      "taskReferenceName": "cmt",
      "type": "SIMPLE",
      "inputParameters": {
        "repoPath": "${wt.output.worktreePath}",
        "message": "code_subtask ${workflow.input.name}"
      }
    }
  ],
  "outputParameters": {
    "status": "${code.output.status}",
    "agent": "${code.output.agent}",
    "model": "${code.output.model}",
    "filesChanged": "${code.output.filesChanged}",
    "costUsd": "${code.output.costUsd}",
    "tokenUsed": "${code.output.tokenUsed}",
    "numTurns": "${code.output.numTurns}",
    "turns": "${code.output.turns}",
    "branch": "${wt.output.branch}",
    "commit": "${cmt.output.commit}"
  }
}
