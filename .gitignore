# Monorepo-wide ignores (each harness may also have its own .gitignore).
# Defense-in-depth: never commit runtime state — it can contain live tokens / PII from real targets.

# Python / build
**/.venv/
**/venv/
**/__pycache__/
*.pyc
*.egg-info/
**/.pytest_cache/
**/.ruff_cache/

# Per-harness scan/run output + state
**/reports/*
!**/reports/.gitkeep
**/state/
**/workers/state/
# OOB worker: track the source, ignore only its runtime state (port/token info).
**/workers/oob/state.json

# Conductor local-server embedded DB
**/c123.db*
*.db
*.db-shm
*.db-wal

# Env / secrets
**/.env
*.local

# MkDocs build output
/site/

# Blog drafts — kept local, not versioned
**/blog/

# OS / scratch
.DS_Store
**/.scratch/
/.idea
/security-harness/manifests
/site
/security-harness/blog
node_modules/

# Harness runtime state (git worktrees + session/output dirs)
.cc-worktrees/
.conductor-code/
